#!/usr/bin/env python3
"""pb — Product Brain hub CLI.

Usage:
  pb sync [--dry-run] [--rebuild] [--provider NAME] [--hub PATH]
  pb adopt <local-checkout> [--id ID] [--copy] [--hub PATH]
  pb status [--hub PATH]
  pb find <term> [aliases...] [--hub PATH]
  pb version [--check]
  pb --help

`pb adopt` is a one-time migration: it relocates an existing local checkout into the hub's
repos/<id> folder (keeping git history, remote, and uncommitted work) so you work in the hub
from then on — a single copy, no drift.

Provider: graphify's doc/image pass uses an LLM. Pick it with --provider
(gemini | claude | openai | kimi | deepseek | ollama | auto) or in brain.config.json
("graph": {"provider": "gemini"}). Set the matching key, e.g. export GEMINI_API_KEY=...

The hub is your workspace: each app is cloned into repos/<id> as a FULL working clone, and
developers work in it directly — alongside the constitution, specs, vocabulary, and graph.

`pb sync` builds one knowledge graph over your hub's docs + those working clones:
  1. read brain.config.json
  2. pull the hub's own latest changes (safe: only if git repo + upstream + clean tree)
  3. clone each app into repos/<id> (full clone); existing clones are pulled only when safe
     (clean tree, fast-forward) so your uncommitted work is never disturbed
  4. keep repos/ and graph/ out of the hub's Git via .git/info/exclude (not .gitignore, so
     graphify still reads repos/), and write a .graphifyignore so graphify skips its own output
  5. run graphify over the hub into the graph/ folder (incremental via cache)
  6. write graph/sync-report.md

No third-party Python packages required. Needs `git` and `graphify` on PATH
(`pip install graphifyy`).
"""

import argparse
import datetime as dt
import json
import os
import shutil
import subprocess
import sys
from pathlib import Path

CORE_DOCS = ["constitution.md", "vocabulary.md", "domains.md"]

# graphify picks its LLM provider (for the doc/image semantic pass) from env vars.
# We map a friendly provider name to the env var(s) graphify looks for.
PROVIDER_ENV = {
    "gemini":    ["GEMINI_API_KEY", "GOOGLE_API_KEY"],
    "claude":    ["ANTHROPIC_API_KEY"],
    "anthropic": ["ANTHROPIC_API_KEY"],
    "openai":    ["OPENAI_API_KEY"],
    "kimi":      ["MOONSHOT_API_KEY"],
    "deepseek":  ["DEEPSEEK_API_KEY"],
    "ollama":    ["OLLAMA_BASE_URL"],
}
ALL_PROVIDER_KEYS = {k for keys in PROVIDER_ENV.values() for k in keys}


def log(msg): print(f"[pb] {msg}")
def die(msg): print(f"[pb] ERROR: {msg}", file=sys.stderr); sys.exit(1)


def load_config(hub: Path) -> dict:
    cfg = hub / "brain.config.json"
    if not cfg.exists():
        die(f"no brain.config.json in {hub} — is this a hub? (run brainify to create one)")
    try:
        return json.loads(cfg.read_text())
    except json.JSONDecodeError as e:
        die(f"brain.config.json is not valid JSON: {e}")


def have(tool: str) -> bool:
    return shutil.which(tool) is not None


def run(cmd, **kw):
    return subprocess.run(cmd, check=True, **kw)


def safe_git_pull(path: Path, label: str, dry: bool):
    """Fast-forward pull a working tree — but only when it's safe to do so, so a developer's
    uncommitted work is never disturbed."""
    if not (path / ".git").exists():
        log(f"{label}: skipped pull (not a git repo)")
        return
    up = subprocess.run(["git", "-C", str(path), "rev-parse", "--abbrev-ref",
                         "--symbolic-full-name", "@{u}"], capture_output=True, text=True)
    if up.returncode != 0:
        log(f"{label}: skipped pull (no upstream/remote configured)")
        return
    dirty = subprocess.run(["git", "-C", str(path), "status", "--porcelain"],
                           capture_output=True, text=True).stdout.strip()
    if dirty:
        log(f"{label}: skipped pull (uncommitted changes — your work is left untouched)")
        return
    log(f"{label}: fast-forward pull")
    if not dry:
        run(["git", "-C", str(path), "pull", "--ff-only", "--quiet"])


def repos_dir(hub: Path, cfg: dict) -> Path:
    name = cfg.get("workspace", {}).get("repos_dir", "repos")
    return hub / name


def pull_repos(rdir: Path, repos: list, dry: bool, do_pull: bool):
    """Clone each app repo into repos/<id> as a FULL working clone, so developers can work
    in it directly inside the hub (and the graph is built over the live code). Existing clones
    are pulled only when safe (clean tree, fast-forward), never disturbing local work."""
    if not dry:
        rdir.mkdir(parents=True, exist_ok=True)
    for r in repos:
        rid = r.get("id")
        if not rid:
            die(f"each repo needs an 'id' (got {r})")
        url = r.get("url")
        if not url:
            die(f"repo '{rid}' needs a 'url' to clone. Develop inside the hub's repos/{rid} folder.")
        dest = rdir / rid
        if (dest / ".git").exists():
            if do_pull:
                safe_git_pull(dest, f"{rdir.name}/{rid}", dry)
            else:
                log(f"{rdir.name}/{rid}: present (pull skipped)")
        else:
            log(f"clone {rdir.name}/{rid} ({url}) — full working clone you can develop in")
            if not dry:
                run(["git", "clone", "--quiet", url, str(dest)])


def ensure_exclusions(hub: Path, rdir: Path, out: Path, repos: list, dry: bool):
    """Keep the clones + the graph output out of Git — but WITHOUT a tracked .gitignore,
    because graphify honors .gitignore and would then skip the repos. We use:
      - .git/info/exclude  (local, untracked) so Git ignores repos/ and graph/
      - .graphifyignore     so graphify skips its own output, and — when a repo declares "src" —
        skips that repo's non-source top-level entries so the graph focuses on the source.
    """
    repos_name = rdir.name
    out_name = out.relative_to(hub).as_posix().rstrip("/")

    # 1) Git: local exclude (does not affect graphify, which reads .gitignore files)
    git_dir = hub / ".git"
    if git_dir.exists():
        excl = git_dir / "info" / "exclude"
        existing = excl.read_text().splitlines() if excl.exists() else []
        wanted = [f"/{repos_name}/", f"/{out_name}/"]
        add = [w for w in wanted if w not in existing]
        if add:
            log(f"git: excluding {', '.join(w.strip('/') for w in add)} from commits (.git/info/exclude)")
            if not dry:
                excl.parent.mkdir(parents=True, exist_ok=True)
                excl.write_text("\n".join(existing + add).rstrip("\n") + "\n")

    # 2) graphify: skip the generated output; keep the repos in; focus each repo on its "src".
    gfi = hub / ".graphifyignore"
    wanted_lines = [
        "# Managed by Product Brain (pb sync). Edits here are overwritten — change brain.config.json instead.",
        f"{out_name}/",        # don't graph the generated map
        f"!{repos_name}/",     # do graph the pulled apps even if Git ignores them
    ]
    for r in repos:
        rid = r.get("id")
        src_list = r.get("src") or ["."]
        if not rid or "." in src_list:
            continue  # no scoping → graph the whole repo
        repo_path = rdir / rid
        if not repo_path.exists():
            continue
        keep = {s.strip("/").split("/")[0] for s in src_list}   # top-level dirs to keep
        extras = sorted(e.name for e in repo_path.iterdir()
                        if e.name != ".git" and e.name not in keep)
        if extras:
            wanted_lines.append(f"# {rid}: graph only {', '.join(sorted(keep))}")
            wanted_lines += [f"{repos_name}/{rid}/{name}" for name in extras]

    if not gfi.exists() or gfi.read_text().splitlines() != wanted_lines:
        log(f"graphify: writing .graphifyignore (skip {out_name}/, focus repos on their src)")
        if not dry:
            gfi.write_text("\n".join(wanted_lines) + "\n")


def graphify_env(provider: str):
    """Return (env, label) for the chosen provider. 'auto' lets graphify decide."""
    env = os.environ.copy()
    if not provider or provider == "auto":
        return env, "auto-detected by graphify (set GEMINI_API_KEY to prefer Gemini)"
    provider = provider.lower()
    keys = PROVIDER_ENV.get(provider)
    if keys is None:
        die(f"unknown graph provider '{provider}'. Choose one of: {', '.join(sorted(PROVIDER_ENV))} or 'auto'.")
    if not any(env.get(k) for k in keys):
        die(f"provider '{provider}' selected but none of {keys} is set.\n"
            f"      Set it first, e.g.:  export {keys[0]}=your-key")
    # Remove other providers' keys so graphify's auto-detect lands on the chosen one.
    for k in ALL_PROVIDER_KEYS - set(keys):
        env.pop(k, None)
    return env, provider


def run_graphify(content_root: Path, out: Path, dry: bool, rebuild: bool, provider: str):
    cmd = ["graphify", str(content_root), "--out", str(out)]
    cache = out / "cache"
    if dry:
        log("would run: " + " ".join(cmd))
        log(f"provider: {provider}")
        log("cache: would " + ("clear (full rebuild)" if rebuild else "reuse" if cache.exists() else "create"))
        return
    if not have("graphify"):
        die("graphify not found on PATH. Install it: pip install graphifyy")
    env, label = graphify_env(provider)
    log(f"semantic extraction provider: {label}")
    out.mkdir(parents=True, exist_ok=True)
    if rebuild and cache.exists():
        log("clearing graphify cache for a full rebuild…")
        shutil.rmtree(cache, ignore_errors=True)
    elif cache.exists():
        # graphify fingerprints each file by content hash; unchanged files are skipped.
        log("incremental build — reusing graphify cache (unchanged files are skipped)")
    run(cmd, env=env)


def graph_stats(out: Path) -> str:
    gj = out / "graph.json"
    if not gj.exists():
        return "graph.json not found (did graphify run?)"
    try:
        data = json.loads(gj.read_text())
        nodes = len(data.get("nodes", []))
        edges = len(data.get("links", data.get("edges", [])))
        return f"{nodes} nodes, {edges} edges"
    except Exception:
        return "graph.json present (could not parse stats)"


def write_report(hub: Path, cfg: dict, out: Path, dry: bool):
    if dry:
        return
    now = dt.datetime.now().strftime("%Y-%m-%d %H:%M")
    repos = ", ".join(r["id"] for r in cfg.get("repos", []))
    report = out / "sync-report.md"
    report.write_text(
        f"# Sync report\n\n"
        f"**Last sync:** {now}\n\n"
        f"**Repos:** {repos or '(none)'}\n\n"
        f"**Graph:** {graph_stats(out)}\n\n"
        f"_Run `pb sync` again after meaningful code or doc changes._\n"
    )
    log(f"wrote {report.relative_to(hub)}")


def cmd_sync(hub: Path, dry: bool, rebuild: bool, hub_pull: bool, repo_pull: bool, provider: str):
    cfg = load_config(hub)
    repos = cfg.get("repos", [])
    out = hub / cfg.get("graph", {}).get("out", "graph/")
    provider = provider or cfg.get("graph", {}).get("provider", "auto")
    log(f"hub: {hub}")
    log(f"{len(repos)} repo(s): {', '.join(r['id'] for r in repos) or '(none)'}")
    if not dry:
        graphify_env(provider)  # validate provider + key now, before any slow work
    if not have("git"):
        die("git not found on PATH.")
    if hub_pull:
        safe_git_pull(hub, "hub pull", dry)
    rdir = repos_dir(hub, cfg)
    log(f"apps folder: {rdir.name}/ — full working clones; develop in them directly inside the hub")
    pull_repos(rdir, repos, dry, repo_pull)
    ensure_exclusions(hub, rdir, out, repos, dry)
    run_graphify(hub, out, dry, rebuild, provider)
    write_report(hub, cfg, out, dry)
    log("done." if not dry else "dry-run complete (nothing written).")


def _same_remote(a: str, b: str) -> bool:
    norm = lambda u: u.strip().lower().rstrip("/").removesuffix(".git").split("@")[-1].split("//")[-1]
    return bool(a) and bool(b) and norm(a).endswith(norm(b).split("/", 1)[-1])


def cmd_adopt(hub: Path, path: str, rid: str, do_copy: bool, force: bool):
    """One-time migration: relocate an EXISTING local checkout into the hub's repos/ folder,
    preserving its git history, remote, branches, and uncommitted work. After this there's a
    single working copy (in the hub) — no drift. Default is to MOVE; --copy leaves the original
    in place (which then becomes a stale duplicate you should delete)."""
    cfg = load_config(hub)
    if not have("git"):
        die("git not found on PATH.")
    src = Path(path).expanduser()
    if not src.exists():
        die(f"path not found: {src}")
    src = src.resolve()
    if not (src / ".git").exists():
        die(f"{src} is not a git checkout (adopt expects a real repo with its history).")
    if src == hub or hub in src.parents:
        die("that path is already inside the hub.")

    rdir = repos_dir(hub, cfg)
    out = hub / cfg.get("graph", {}).get("out", "graph/")
    origin = subprocess.run(["git", "-C", str(src), "remote", "get-url", "origin"],
                            capture_output=True, text=True)
    origin_url = origin.stdout.strip() if origin.returncode == 0 else ""

    if not rid:
        for r in cfg.get("repos", []):
            if _same_remote(r.get("url", ""), origin_url):
                rid = r["id"]; break
        rid = rid or src.name
    dest = rdir / rid
    if dest.exists():
        if not force:
            die(f"{dest} already exists — remove it, pass --force to replace it, or choose a different --id.")
        log(f"removing existing {dest} (--force)")
        shutil.rmtree(dest)

    rdir.mkdir(parents=True, exist_ok=True)
    action = "copy" if do_copy else "move"
    log(f"{action} {src} → {dest}")
    log("  (preserving git history, remote, branches, and any uncommitted work)")
    if do_copy:
        shutil.copytree(src, dest, symlinks=True)
    else:
        shutil.move(str(src), str(dest))

    ids = [r.get("id") for r in cfg.get("repos", [])]
    if rid not in ids:
        cfg.setdefault("repos", []).append({"id": rid, "url": origin_url, "src": ["."]})
        (hub / "brain.config.json").write_text(json.dumps(cfg, indent=2) + "\n")
        log(f"registered '{rid}' in brain.config.json — set its \"src\" dirs (e.g. [\"app/\"]) if needed")
    elif origin_url:
        cfgd = next(r for r in cfg["repos"] if r.get("id") == rid)
        if cfgd.get("url") and not _same_remote(cfgd["url"], origin_url):
            log(f"  ! note: config url for '{rid}' differs from this checkout's origin ({origin_url})")

    ensure_exclusions(hub, rdir, out, cfg.get("repos", []), dry=False)
    log(f"done — develop in {dest} from now on. Run `pb sync` to (re)build the graph.")
    if do_copy:
        log(f"  reminder: your original at {src} is now a stale duplicate — delete it to avoid confusion.")


def framework_root() -> Path:
    return Path(__file__).resolve().parent.parent


def read_version() -> str:
    vf = framework_root() / "VERSION"
    return vf.read_text().strip() if vf.exists() else "unknown"


def _skill_version(skill_dir: Path):
    f = skill_dir / "SKILL.md"
    if not f.exists():
        return None
    for line in f.read_text().splitlines():
        if line.strip().lower().startswith("version:"):
            return line.split(":", 1)[1].strip()
    return "unversioned"


def report_installed_skill():
    root = framework_root()
    repo_v = _skill_version(root / "skills" / "brainify")
    locations = [(Path.home() / ".claude" / "skills" / "brainify", "personal"),
                 (Path.cwd() / ".claude" / "skills" / "brainify", "project")]
    found = False
    for loc, label in locations:
        if not loc.exists():
            continue
        found = True
        if loc.is_symlink():
            print(f"installed skill ({label}): linked to the repo — always current")
        else:
            iv = _skill_version(loc)
            if iv == repo_v:
                print(f"installed skill ({label}): {iv} — up to date")
            else:
                print(f"installed skill ({label}): {iv} — repo has {repo_v}; re-run bin/install-skill.sh")
    if not found:
        print("installed skill: not found in ~/.claude/skills or ./.claude/skills "
              "(run bin/install-skill.sh)")


def cmd_version(check: bool):
    root = framework_root()
    print(f"Product Brain {read_version()}")
    if (root / ".git").exists() and have("git"):
        sha = subprocess.run(["git", "-C", str(root), "log", "-1", "--format=%h (%cs)"],
                             capture_output=True, text=True).stdout.strip()
        if sha:
            print(f"commit: {sha}")
    report_installed_skill()
    if not check:
        print("Run `pb version --check` to see if a newer version exists upstream.")
        return
    if not ((root / ".git").exists() and have("git")):
        print("check: not a git checkout — can't compare with upstream.")
        return
    fetch = subprocess.run(["git", "-C", str(root), "fetch", "--quiet"], capture_output=True, text=True)
    if fetch.returncode != 0:
        print("check: couldn't reach the remote (offline or no access).")
        return
    up = subprocess.run(["git", "-C", str(root), "rev-parse", "--abbrev-ref",
                         "--symbolic-full-name", "@{u}"], capture_output=True, text=True)
    if up.returncode != 0:
        print("check: no upstream branch configured.")
        return
    behind = subprocess.run(["git", "-C", str(root), "rev-list", "--count", "HEAD..@{u}"],
                            capture_output=True, text=True).stdout.strip()
    ahead = subprocess.run(["git", "-C", str(root), "rev-list", "--count", "@{u}..HEAD"],
                           capture_output=True, text=True).stdout.strip()
    if behind and int(behind) > 0:
        print(f"⬇️  {behind} update(s) available upstream. Run: git -C {root} pull")
    elif ahead and int(ahead) > 0:
        print(f"✅ up to date (and {ahead} local commit(s) not yet pushed).")
    else:
        print("✅ up to date — you have the latest version.")


def cmd_find(hub: Path, terms: list, code_only: bool, limit: int, repo: str):
    """Search the built graph for code symbols matching a product term + its aliases.
    This is what powers graph-assisted vocabulary: don't guess code names — look them up.
    Pass --repo <id> to scope the search to one repo (e.g. backend-only questions)."""
    cfg = load_config(hub)
    out = hub / cfg.get("graph", {}).get("out", "graph/")
    gj = out / "graph.json"
    if not gj.exists():
        die("no graph yet — run `pb sync` first, then `pb find <term>`.")
    if repo:
        known = [r.get("id") for r in cfg.get("repos", [])]
        if repo not in known:
            die(f"unknown repo '{repo}'. Known: {', '.join(known) or '(none)'}")
    try:
        data = json.loads(gj.read_text())
    except Exception as e:
        die(f"couldn't read {gj}: {e}")
    q = [t.lower() for t in terms]
    results = []
    for n in data.get("nodes", []):
        label = str(n.get("label", n.get("id", "")))
        ft = str(n.get("file_type", ""))
        src = str(n.get("source_file", ""))
        if code_only and ft != "code":
            continue
        if repo and f"repos/{repo}/" not in src.replace("\\", "/"):
            continue
        hay = label.lower()
        score = 0
        for t in q:
            if not t:
                continue
            if t == hay:
                score += 4
            elif t in hay or hay in t:
                score += 3
            else:
                toks = [tok for tok in t.replace("-", " ").replace("_", " ").split() if tok]
                score += sum(1 for tok in toks if tok in hay)
        if score > 0:
            results.append((score, label, ft, str(n.get("source_file", ""))))
    if not results:
        print(f"no matches for: {', '.join(terms)}")
        return
    results.sort(key=lambda x: (-x[0], x[1]))
    scope = f" (scoped to repo: {repo})" if repo else ""
    print(f"Candidate code symbols for: {', '.join(terms)}{scope}")
    for score, label, ft, src in results[:limit]:
        tag = f" [{ft}]" if ft else ""
        loc = f"  — {src}" if src else ""
        print(f"  {label}{tag}{loc}")


def cmd_status(hub: Path):
    cfg = load_config(hub)
    out = hub / cfg.get("graph", {}).get("out", "graph/")
    print(f"Hub: {hub}")
    print(f"Repos: {', '.join(r['id'] for r in cfg.get('repos', [])) or '(none)'}")
    print(f"Doc types: {', '.join(cfg.get('doc_types', [])) or '(none)'}")
    for d in CORE_DOCS:
        mark = "ok" if (hub / d).exists() else ("absent" if d == "domains.md" else "MISSING")
        print(f"  {d}: {mark}")
    gj = out / "graph.json"
    if gj.exists():
        age = (dt.datetime.now() - dt.datetime.fromtimestamp(gj.stat().st_mtime)).days
        print(f"Graph: {graph_stats(out)} ({age}d old)")
    else:
        print("Graph: not built — run `pb sync`")


def main():
    p = argparse.ArgumentParser(prog="pb", description="Product Brain hub CLI")
    p.add_argument("--hub", default=".", help="path to the hub repo (default: current dir)")
    sub = p.add_subparsers(dest="cmd", required=True)
    s = sub.add_parser("sync", help="pull repos and (re)build the graph (incremental by default)")
    s.add_argument("--dry-run", action="store_true", help="show the plan without writing or running graphify")
    s.add_argument("--rebuild", action="store_true", help="clear the graphify cache and rebuild everything from scratch")
    s.add_argument("--no-hub-pull", action="store_true", help="don't pull the hub's own latest changes first")
    s.add_argument("--no-repo-pull", action="store_true", help="don't pull the app working clones (leave them exactly as they are)")
    s.add_argument("--provider", help="LLM provider for graphify's doc/image pass: "
                   "gemini | claude | openai | kimi | deepseek | ollama | auto (overrides brain.config.json)")
    sub.add_parser("status", help="show hub health at a glance")
    a = sub.add_parser("adopt", help="move an existing local checkout into the hub (one-time, keeps git history + uncommitted work)")
    a.add_argument("path", help="path to your existing local checkout")
    a.add_argument("--id", help="repo id to use under repos/ (default: matched from config, else folder name)")
    a.add_argument("--copy", action="store_true", help="copy instead of move (leaves a stale duplicate behind)")
    a.add_argument("--force", action="store_true", help="replace repos/<id> if it already exists")
    f = sub.add_parser("find", help="search the graph for code symbols matching a term (powers vocabulary)")
    f.add_argument("terms", nargs="+", help="the product term and/or its aliases, e.g. find session booking appointment")
    f.add_argument("--code-only", action="store_true", help="only return code symbols (skip docs)")
    f.add_argument("--repo", help="scope the search to one repo id (e.g. backend-api)")
    f.add_argument("--limit", type=int, default=15, help="max results (default 15)")
    v = sub.add_parser("version", help="show the Product Brain version (and check for updates)")
    v.add_argument("--check", action="store_true", help="fetch and report whether a newer version exists upstream")
    args = p.parse_args()

    if args.cmd == "version":
        cmd_version(args.check)
        return

    hub = Path(args.hub).resolve()
    if not hub.exists():
        die(f"hub path does not exist: {hub}")
    try:
        if args.cmd == "sync":
            cmd_sync(hub, args.dry_run, args.rebuild, not args.no_hub_pull, not args.no_repo_pull, args.provider)
        elif args.cmd == "status":
            cmd_status(hub)
        elif args.cmd == "adopt":
            cmd_adopt(hub, args.path, args.id, args.copy, args.force)
        elif args.cmd == "find":
            cmd_find(hub, args.terms, args.code_only, args.limit, args.repo)
    except subprocess.CalledProcessError as e:
        die(f"command failed: {' '.join(str(c) for c in e.cmd)}")


if __name__ == "__main__":
    main()
